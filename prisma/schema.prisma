// ─── Prisma Schema — VALLIDATOR Production ────────────────────────────────────
// Next.js 14 + PostgreSQL + pgvector

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth.js v5 required models ──────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core domain models ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   // bcrypt hash (credentials login)
  startupName   String?

  // Gamification
  xp            Int       @default(0)
  streak        Int       @default(0)
  level         Int       @default(1)
  lastVisitAt   DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  diagnoses     Diagnosis[]
  subscription  Subscription?
  waitlistEntry WaitlistEntry?
  analyticsEvents AnalyticsEvent[]

  @@index([email])
}

model Diagnosis {
  id              String   @id @default(cuid())
  userId          String

  // Score data
  phase           String   @default("genesis")
  overallScore    Int
  dimensions      Json     // DimensionResult[] — { label, score, color, status, interpretation }
  weakestDim      String
  strongestDim    String

  // Input data (stored for re-calculation and audit)
  formAnswers     Json     // FormAnswers from the 4-block form
  calAnswers      Json?    // CalibrationAnswers (5 questions)

  // AI output
  parecerAbertura  String?  @db.Text
  parecerRisco     String?  @db.Text
  parecerForca     String?  @db.Text
  parecerPasso     String?  @db.Text
  parecerSource    String?  // 'gpt-4o-mini' | 'deterministic'

  // Investor readiness
  investorStage   String?  // 'pre-seed' | 'seed' | 'serie-a'

  completedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([completedAt])
  @@index([overallScore])
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique

  plan             String    @default("explorer")  // 'explorer' | 'navigator'
  status           String    @default("active")    // 'active' | 'cancelled' | 'past_due'

  // Payment providers
  stripeCustomerId    String?  @unique
  stripeSubId         String?  @unique
  pagarmeCustomerId   String?

  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean   @default(false)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  userId    String?  @unique
  source    String?  // 'landing' | 'pre-check' | etc.
  joinedAt  DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  event     String
  props     Json?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([event])
  @@index([userId])
  @@index([createdAt])
}

# ─── VALLIDATOR — Variáveis de Ambiente ──────────────────────────────────────
# Copie este arquivo para .env.local e preencha os valores.
# NÃO commite .env.local no git.

# ── Banco de Dados ─────────────────────────────────────────────────────────────
# PostgreSQL (Supabase, Neon, Railway, ou Vercel Postgres)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/vallidator?schema=public"

# ── NextAuth.js ────────────────────────────────────────────────────────────────
# Gere um secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# URL pública do app (sem barra no final)
# Desenvolvimento: http://localhost:3000
# Produção: https://vallidator.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ── OAuth — GitHub ─────────────────────────────────────────────────────────────
# Crie em: https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID="your-github-oauth-app-id"
GITHUB_SECRET="your-github-oauth-app-secret"

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Obtido em: https://platform.openai.com/api-keys
# Se não configurado, o Parecer IA usa fallback determinístico
OPENAI_API_KEY="sk-..."

# ── Resend (e-mail transacional) ──────────────────────────────────────────────
# Obtido em: https://resend.com/api-keys
# Se não configurado, envio de e-mail é desativado silenciosamente
RESEND_API_KEY="re_..."

# ── Stripe (pagamentos) ───────────────────────────────────────────────────────
# Chave secreta: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."

# Webhook secret (gerado no Stripe Dashboard ou via: stripe listen --print-secret)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Stripe — Price IDs dos planos ─────────────────────────────────────────────
# Crie os produtos no Stripe Dashboard e cole os Price IDs abaixo
STRIPE_PRICE_MENTOR="price_..."
STRIPE_PRICE_BOARD="price_..."
STRIPE_PRICE_SERIES_A="price_..."

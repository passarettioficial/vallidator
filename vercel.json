{
  "buildCommand": "npx prisma generate && npx prisma db push --accept-data-loss && next build",
  "framework": "nextjs",
  "headers": [
    {
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ],
      "source": "/api/(.*)"
    }
  ],
  "installCommand": "npm install",
  "outputDirectory": ".next"
}